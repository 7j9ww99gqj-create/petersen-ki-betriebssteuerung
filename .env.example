# Petersen KI Betriebssteuerung – Umgebungsvariablen
# Kopieren Sie diese Datei als .env.local und tragen Sie Ihre Werte ein

# Anthropic API Key – für echte KI-Funktionen
# Erhältlich auf: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# App-Konfiguration
NEXT_PUBLIC_APP_NAME="Petersen KI Betriebssteuerung"
NEXT_PUBLIC_DEMO_MODE=true

# Stripe / Checkout
# Niemals echte Zugangsdaten committen.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FALLBACK_IBAN=

# Nur serverseitig fuer abgesicherte Webhooks/Owner-Syncs verwenden
SUPABASE_SERVICE_ROLE_KEY=

# Resend – Mail-Versand (Rechnungen, Angebote, Automatisierungen)
# Account anlegen: https://resend.com – kostenlos bis 100 Mails/Tag
# Domain-Verifikation einmalig im Resend-Dashboard notwendig
RESEND_API_KEY=
# Absender-Adresse (muss zu verifizierter Domain passen)
MAIL_FROM_ADDRESS=rechnungen@petersen-ki-pilot.de
